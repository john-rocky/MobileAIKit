    <string>Record a short voice note for your moment.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Transcribe your voice note on-device.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Attach photos to your moment.</string>
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>Attach the current location to your moment.</string>
